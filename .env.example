# =============================================================================
# AI Document Assistant — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: openai | anthropic | ollama
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Ollama (required if LLM_PROVIDER=ollama) — fully local, free
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── App Settings ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-32-char-string

# ── Vector Store ───────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=faiss          # faiss | chroma
VECTOR_STORE_PATH=./data/vectorstore
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SIMILARITY_TOP_K=5

# ── Redis (conversation memory) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CONVERSATION_TTL_SECONDS=3600

# ── ChromaDB (if VECTOR_STORE_TYPE=chroma) ─────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── RAG Pipeline ───────────────────────────────────────────────────────────────
RETRIEVER_SEARCH_TYPE=mmr
ENABLE_RERANKING=true
ENABLE_HYDE=false
LLM_TEMPERATURE=0.1

# ── Evaluation ─────────────────────────────────────────────────────────────────
ENABLE_TRACING=true
RAGAS_LLM_MODEL=gpt-4o-mini

# ── Monitoring ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me
METRICS_ENABLED=true
